# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# Django
*.log
local_settings.py
db.sqlite3
staticfiles/

# Environment files (contain secrets)
.env
.env.*
*.env

# IDE/Editor
.vscode/
.idea/
.claude/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Project specific
data/
nul
# Internal docs stay local, except the public plugin author guide.
docs/*
!docs/plugins.md

# Plugins are installed at runtime onto the data volume — keep the package
# marker + readme in the repo, ignore everything actually uploaded.
plugins/*
!plugins/__init__.py
!plugins/README.md

# Local-only UI design mockups (scratch exploration, not shipped)
design-preview/

# Built plugin packages — reproducible from the source dirs under examples/
examples/*.zip

# Separate landing site project (has its own repo)
landing/
