# =============================================================================
# PyRunner configuration. Copy this file to `.env` and fill in the required
# values. Commented-out vars show their built-in default — uncomment to override.
# Only SECRET_KEY and ENCRYPTION_KEY are strictly required.
# =============================================================================

# --- Django core -------------------------------------------------------------
# REQUIRED. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-django-secret-key-here

# Debug mode. MUST stay False in production — True leaks verbose error pages and
# relaxes security. Set True only for local development (also enables plugin dev mode).
DEBUG=False

# Comma-separated hostnames this instance answers on (loopback is always allowed).
ALLOWED_HOSTS=localhost,127.0.0.1

# --- HTTPS / cookies (applied when DEBUG=False) ------------------------------
# 301 http->https. Default True in production; set False behind an edge-TLS proxy
# (e.g. Coolify) or for a genuine plain-http run.
SECURE_SSL_REDIRECT=False
# Secure cookies require HTTPS. Keep True for production (incl. edge-TLS proxies).
# Set False ONLY for a genuine plain-http deployment — otherwise the session
# cookie is never sent back and you get logged out on every request.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
# HSTS (production only). Start conservative, then raise once confirmed working.
# SECURE_HSTS_SECONDS=2592000            # 30 days (default). 31536000 = 1 year.
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False

# --- Database ----------------------------------------------------------------
# Leave DATABASE_URL unset to use the zero-config SQLite default (data/db.sqlite3).
# Set it to run on Postgres instead — the only change needed to switch engines:
#   DATABASE_URL=postgres://pyrunner:password@db:5432/pyrunner
# DATABASE_URL=
# Persistent-connection lifetime in seconds (Postgres only).
# DB_CONN_MAX_AGE=600
#
# Postgres credentials (only used by docker-compose.postgres.yml, which builds
# DATABASE_URL from these and runs a managed Postgres service):
# POSTGRES_USER=pyrunner
# POSTGRES_PASSWORD=change-me-please
# POSTGRES_DB=pyrunner

# --- Databases (managed Postgres for scripts & plugins) -----------------------
# Optional. Attach a Postgres server to enable the Databases feature: real SQL
# databases (schemas) that admins provision and scripts/plugins connect to via
# the pyrunner_db helper. Independent of DATABASE_URL — works with SQLite core.
# Must point at a SEPARATE database from the core one (never share it), with a
# provisioner user that can CREATE SCHEMA on it and CREATE ROLE (not superuser):
#   CREATE ROLE pyrunner_provisioner LOGIN PASSWORD '...' CREATEROLE;
#   CREATE DATABASE pyrunner_data OWNER pyrunner_provisioner;
# If the core PyRunner database is on the SAME server, also keep script roles
# from connecting to it (the core app user is its owner and is unaffected):
#   REVOKE CONNECT, TEMPORARY ON DATABASE <core-db-name> FROM PUBLIC;
# Optional, for the Databases monitor page (activity/slow-query text + stats):
#   GRANT pg_read_all_stats TO pyrunner_provisioner;
#   -- and, inside pyrunner_data (needs shared_preload_libraries=pg_stat_statements):
#   CREATE EXTENSION IF NOT EXISTS pg_stat_statements;
# PYRUNNER_DATA_DB_URL=postgres://pyrunner_provisioner:password@db:5432/pyrunner_data
#
# docker-compose.postgres.yml wires all of this up automatically on a fresh
# volume (docker/init-data-db.sh) — override its defaults here if you like:
# DATA_DB_NAME=pyrunner_data
# DATA_DB_PASSWORD=change-me-too
#
# Hygiene stamped on every provisioned database role (uncomment to override):
# PYRUNNER_DATA_DB_STATEMENT_TIMEOUT_MS=300000   # per-statement cap; 0 = off
# PYRUNNER_DATA_DB_CONNECTION_LIMIT=10           # concurrent connections per database
#
# Note: if you override PYRUNNER_RUN_ENV_DENYLIST yourself, keep
# PYRUNNER_DATA_DB_URL in it so scripts never inherit the provisioner credential.

# --- Cache -------------------------------------------------------------------
# Rate limiting and webhook dedup use a shared cache across all processes. The
# default is DatabaseCache (no extra service needed). Set REDIS_URL to use Redis
# instead — recommended when scaling to many workers or multiple hosts.
# REDIS_URL=redis://localhost:6379/0

# --- Email -------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@pyrunner.local
RESEND_API_KEY=
USE_RESEND=False

# --- Workers & web server ----------------------------------------------------
# django-q2 background task workers.
Q_WORKERS=2
# Gunicorn (web server) tuning.
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120
# Host port to publish the container on (compose maps PORT -> container :8000).
# PORT=8000

# --- Security / API limits ---------------------------------------------------
# Lock an account after this many failed logins (django-axes).
# AXES_FAILURE_LIMIT=5
# API requests allowed per minute per token.
# API_RATE_LIMIT=60
# Trusted reverse-proxy hops in front of PyRunner. 0 (default) keys the per-IP
# webhook/channel rate limits on the direct peer (REMOTE_ADDR); behind a proxy that
# is the proxy's IP for everyone, so set this to the number of trusted proxies (e.g.
# 1 for a single Coolify/Traefik edge) to key on the real client IP from
# X-Forwarded-For.
# RATELIMIT_TRUSTED_PROXY_DEPTH=0
# Allowed CORS origins for the API. "*" suits a self-hosted single tenant;
# otherwise a comma-separated list of origins.
# API_CORS_ORIGINS=*

# --- Per-run resource limits (POSIX only; 0 = off) ---------------------------
# Applied to each script subprocess via setrlimit. No-op on Windows.
# PYRUNNER_RUN_RLIMIT_MEMORY_MB=0
# PYRUNNER_RUN_RLIMIT_CPU_SECONDS=0
# PYRUNNER_RUN_RLIMIT_NPROC=0

# --- Secrets encryption ------------------------------------------------------
# REQUIRED. Fernet key used to encrypt stored secrets — save it somewhere safe;
# losing it makes existing encrypted secrets unrecoverable. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here
